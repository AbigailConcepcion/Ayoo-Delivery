# Server Environment Variables Template
# Copy to server/.env and fill values
# Restart server after changes: npm --prefix server run dev

PORT=4000
JWT_SECRET=your-super-secure-jwt-secret-change-this-in-production-min-32-chars
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
PAYMONGO_SECRET_KEY=pkmp_your_paymongo_key_here_optional
DATABASE_URL=./ayoo.sqlite
NODE_ENV=production
MASTER_PIN=your-secure-6-digit-pin-not-1234
ALLOWED_ORIGINS=http://localhost:5173,https://your-app-domain.com,capacitor://localhost
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Client Vite vars (VITE_ prefix required)
# Add to root .env
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here
VITE_API_URL=http://localhost:4000
VITE_APP_ENV=development
