# Ayoo Delivery Environment Variables Template
# Copy this file to .env and fill in your actual values

# Backend API Configuration
VITE_API_BASE=http://localhost:4000

# Enable real backend (set to 'true' to use real backend, 'false' for local storage)
VITE_USE_REAL_BACKEND='true'

# Optional: PayMongo API Keys (for payment processing)
# VITE_PAYMONGO_PUBLIC_KEY=pk_your_public_key

# Optional: Map/Location Services
# VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key

